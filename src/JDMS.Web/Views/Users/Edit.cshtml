@model UserEditViewModel
@{ ViewData["Title"] = "تعديل مستخدم"; }

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card">
        <div class="card-header">بيانات المستخدم</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" required />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select" required>
                        <option value="@Roles.Administrator">@RoleLabels.ToArabic(Roles.Administrator)</option>
                        <option value="@Roles.Manager">@RoleLabels.ToArabic(Roles.Manager)</option>
                        <option value="@Roles.Employee">@RoleLabels.ToArabic(Roles.Employee)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">تغيير كلمة المرور (اختياري)</div>
        <div class="card-body">
            <p class="small text-muted mb-3">اترك الحقول فارغة إذا لا تريد تغيير كلمة المرور.</p>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmNewPassword" class="form-label"></label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
