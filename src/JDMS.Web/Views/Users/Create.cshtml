@model UserCreateViewModel
@{ ViewData["Title"] = "مستخدم جديد"; }

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card">
        <div class="card-header">بيانات الدخول (إلزامية)</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" autocomplete="off" placeholder="مثال: ahmad" required />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" required />
                    <span class="form-text small">6 أحرف على الأقل، حرف كبير وصغير ورقم</span>
                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">الصلاحية والبريد</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select" required>
                        <option value="">— اختر الصلاحية —</option>
                        <option value="@Roles.Administrator">@RoleLabels.ToArabic(Roles.Administrator)</option>
                        <option value="@Roles.Manager">@RoleLabels.ToArabic(Roles.Manager)</option>
                        <option value="@Roles.Employee">@RoleLabels.ToArabic(Roles.Employee)</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="اختياري — يُنشأ تلقائياً إن تُرك فارغاً" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">حفظ المستخدم</button>
        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
