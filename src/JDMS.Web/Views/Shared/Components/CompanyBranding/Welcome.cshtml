@model JDMS.Application.DTOs.CompanyBrandingDto
<div class="card jdms-welcome-card mb-4 border-0 shadow-sm">
    <div class="card-body d-flex flex-wrap align-items-center gap-4">
        <img src="@Model.LogoUrl" alt="@Model.CompanyName" class="jdms-logo-welcome" asp-append-version="true" />
        <div class="flex-grow-1">
            <h4 class="mb-1">مرحباً بك في @Model.CompanyName</h4>
            <p class="text-muted mb-1">@DateTime.Now.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar-JO"))</p>
            <span class="badge text-bg-primary">إصدار النظام @Model.SystemVersion</span>
        </div>
    </div>
</div>
