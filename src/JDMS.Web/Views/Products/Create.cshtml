@model ProductCreateDto
@{ ViewData["Title"] = "إضافة منتج"; }
<form method="post">@Html.AntiForgeryToken()
<div class="row g-3">
<div class="col-md-6"><label>اسم المنتج</label><input asp-for="ProductName" class="form-control" required/></div>
<div class="col-md-6"><label>SKU</label><input asp-for="SKU" class="form-control" required/></div>
<div class="col-md-6"><label>الباركود</label><input asp-for="Barcode" class="form-control"/></div>
<div class="col-md-6"><label>رابط الصورة</label><input asp-for="ImagePath" class="form-control" placeholder="/images/products/..."/></div>
<div class="col-md-6"><label>السعر</label><input asp-for="UnitPrice" class="form-control" type="number" step="0.01" required/></div>
<div class="col-md-6"><label class="form-check mt-4"><input asp-for="IsActive" class="form-check-input"/> نشط</label></div>
<div class="col-12"><label>الوصف</label><textarea asp-for="Description" class="form-control"></textarea></div>
</div><button class="btn btn-primary mt-3">حفظ</button></form>
